# Chave secreta para JWT (mínimo 32 caracteres em produção)
SECRET_KEY=desenvolvimento-local-chave-secreta-32chars-minimo

# Algoritmo de assinatura do token
ALGORITHM=HS256

# Tempo de expiração do token em minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# URL do banco de dados (SQLite padrão)
# Para PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./database.db

# Chave de criptografia (opcional, para dados sensíveis)
ENCRYPTION_KEY=

# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
