# Backend: ruff, bandit, etc. (usa venv do backend se existir)
if [ -f backend/.venv/Scripts/python.exe ]; then
  backend/.venv/Scripts/python.exe -m pre_commit run
elif [ -f backend/.venv/bin/python ]; then
  backend/.venv/bin/python -m pre_commit run
else
  python -m pre_commit run
fi

